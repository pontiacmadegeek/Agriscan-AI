rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global helper methods
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_-]+$');
    }

    // Validation Blueprint for Portfolio Documents
    function isValidPortfolio(data) {
      return data != null
        && 'id' in data && data.id is string && data.id.size() <= 128
        && 'name' in data && data.name is string && data.name.size() <= 200
        && 'ownerId' in data && data.ownerId is string && data.ownerId.size() <= 128;
    }

    // Rules for individual portfolios collection
    match /portfolios/{portfolioId} {
      allow get: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      
      // Forces the client to securely use .where("ownerId", "==", uid) and prevents blanket listing
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      
      allow create: if isSignedIn()
        && isValidId(portfolioId)
        && isValidPortfolio(request.resource.data)
        && request.resource.data.ownerId == request.auth.uid;

      allow update: if isSignedIn()
        && isValidId(portfolioId)
        && isValidPortfolio(request.resource.data)
        && resource.data.ownerId == request.auth.uid
        && request.resource.data.ownerId == resource.data.ownerId; // Enforces ownerId immutability

      allow delete: if isSignedIn()
        && isValidId(portfolioId)
        && resource.data.ownerId == request.auth.uid;
    }
  }
}
